# Admin authentication secret — keep this strong and private
ADMIN_SECRET=your-admin-secret-here

# JWT signing secret — used to sign session tokens issued after code redemption
APP_SECRET=your-jwt-signing-secret-here

# GitHub personal access token with org:write scope
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# The GitHub organization name to invite testers to
GITHUB_ORG=your-org-name

# Download configuration — set ONE of the following:
# Option A: Redirect to an external URL (e.g., S3 pre-signed URL or CDN link)
DOWNLOAD_URL=https://example.com/dirac.dmg

# Option B: Serve a local file from the server filesystem
# DOWNLOAD_FILE_PATH=/absolute/path/to/dirac.dmg
