# Admin authentication secret — keep this strong and private
ADMIN_SECRET=your-admin-secret-here

# JWT signing secret — used to sign session tokens issued after code redemption
APP_SECRET=your-jwt-signing-secret-here

# Vercel Postgres connection URL
POSTGRES_URL=postgres://...

# The URL of the hosted Dirac beta app testers are sent to after code validation
NEXT_PUBLIC_TESTER_URL=https://your-dirac-beta-url.vercel.app
